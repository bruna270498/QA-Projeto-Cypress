{
  "name": "task01",
  "version": "1.0.0",
  "main": "index.js",
"scripts": {
  "cy:open": "cypress open",
  "cy:run": "cypress run",
  "cy:run:browser": "cypress run --headed --browser chrome",
  "cy:run:test": "cypress run --headed --browser chrome --spec",
  "cy:allure": "cypress run --env allure=true",
  "allure:report": "allure generate allure-results --clean -o allure-report",
  "allure:open": "allure open allure-report",
  "allure:run": "npm run cy:allure && npm run allure:report && npm run allure:open"
},
